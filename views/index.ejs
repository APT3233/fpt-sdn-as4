<%- include('partials/header', { title: 'Trang Chủ' , activePage: 'home' }) %>

    <div class="container">
        <!-- Hero Section -->
        <div class="hero hero-image">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <div class="hero-badge">🏆 Hệ Thống Quản Lý Xe Hàng Đầu</div>
                <h1>Car Rental System</h1>
                <p>Quản lý đội xe và đặt chỗ của bạn một cách thông minh, hiệu quả và chuyên nghiệp.</p>
                <div class="actions">
                    <a href="/cars" class="btn btn-primary">🚙 Quản Lý Xe</a>
                    <a href="/bookings" class="btn btn-outline">📅 Xem Đặt Xe</a>
                </div>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon stat-icon--blue">🚗</div>
                <div class="stat-info">
                    <span class="stat-value">
                        <%= stats.totalCars %>
                    </span>
                    <span class="stat-label">Tổng Số Xe</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon--green">✅</div>
                <div class="stat-info">
                    <span class="stat-value">
                        <%= stats.availableCars %>
                    </span>
                    <span class="stat-label">Xe Sẵn Sàng</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon--orange">🔑</div>
                <div class="stat-info">
                    <span class="stat-value">
                        <%= stats.rentedCars %>
                    </span>
                    <span class="stat-label">Xe Đang Thuê</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon--purple">📋</div>
                <div class="stat-info">
                    <span class="stat-value">
                        <%= stats.totalBookings %>
                    </span>
                    <span class="stat-label">Tổng Đặt Xe</span>
                </div>
            </div>
        </div>

        <!-- Feature Cards -->
        <div class="section-title" style="margin-top: 3rem;">
            <h2>Tính Năng Nổi Bật</h2>
            <p>Tất cả những gì bạn cần để quản lý hệ thống thuê xe hiệu quả</p>
        </div>
        <div class="grid">
            <div class="card feature-card">
                <div class="feature-icon">🚗</div>
                <h3>Quản Lý Đội Xe</h3>
                <p>Theo dõi toàn bộ đội xe của bạn — trạng thái, giá thuê, tính năng và sức chứa theo thời gian thực.
                </p>
                <a href="/cars" class="card-link">Xem Xe →</a>
            </div>
            <div class="card feature-card">
                <div class="feature-icon">📅</div>
                <h3>Hệ Thống Đặt Xe</h3>
                <p>Quản lý đặt chỗ của khách hàng một cách liền mạch, tự động tính toán tổng tiền thuê.</p>
                <a href="/bookings" class="card-link">Xem Đặt Xe →</a>
            </div>
            <div class="card feature-card">
                <div class="feature-icon">⚡</div>
                <h3>Kiểm Tra Xung Đột</h3>
                <p>Hệ thống tự động phát hiện và ngăn chặn các đặt chỗ trùng lặp cho cùng một xe.</p>
                <a href="/bookings" class="card-link">Tìm Hiểu →</a>
            </div>
        </div>

        <!-- Recent Bookings Preview -->
        <% if (recentBookings && recentBookings.length> 0) { %>
            <div class="section-title" style="margin-top: 3rem;">
                <h2>Đặt Xe Gần Đây</h2>
                <p>5 giao dịch đặt xe mới nhất trong hệ thống</p>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Khách Hàng</th>
                            <th>Xe</th>
                            <th>Ngày Thuê</th>
                            <th>Ngày Trả</th>
                            <th>Tổng Tiền</th>
                            <th>Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentBookings.forEach(function(booking) { %>
                            <% const now=new Date(); const start=new Date(booking.startDate); const end=new
                                Date(booking.endDate); let statusClass='status-available' ; let
                                statusText='Đang Hoạt Động' ; if (end < now) { statusClass='status-completed' ;
                                statusText='Hoàn Thành' ; } else if (start> now) {
                                statusClass = 'status-rented';
                                statusText = 'Sắp Tới';
                                }
                                %>
                                <tr>
                                    <td style="font-weight: 500;">👤 <%= booking.customerName %>
                                    </td>
                                    <td><code class="car-code"><%= booking.carNumber %></code></td>
                                    <td>
                                        <%= new Date(booking.startDate).toLocaleDateString('vi-VN') %>
                                    </td>
                                    <td>
                                        <%= booking.endDate ? new Date(booking.endDate).toLocaleDateString('vi-VN')
                                            : '—' %>
                                    </td>
                                    <td class="amount">
                                        <%= booking.totalAmount.toLocaleString('vi-VN') %> ₫
                                    </td>
                                    <td><span class="status <%= statusClass %>">
                                            <%= statusText %>
                                        </span></td>
                                </tr>
                                <% }); %>
                    </tbody>
                </table>
            </div>
            <div style="text-align: right; margin-top: 1rem;">
                <a href="/bookings" class="btn btn-action" style="text-decoration:none;">Xem Tất Cả →</a>
            </div>
            <% } %>
    </div>

    <%- include('partials/footer') %>