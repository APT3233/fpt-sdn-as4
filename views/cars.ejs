<%- include('partials/header', { title: 'Quản Lý Xe' , activePage: 'cars' }) %>

    <div class="container">
        <div class="page-header">
            <div class="section-title">
                <h2>🚙 Quản Lý Đội Xe</h2>
                <p>Xem và quản lý toàn bộ đội xe trong hệ thống.</p>
            </div>
            <button class="btn btn-action" onclick="openCarModal()">
                ➕ Thêm Xe Mới
            </button>
        </div>

        <!-- Filter Bar -->
        <div class="filter-bar">
            <div class="filter-group">
                <label for="filterStatus">Trạng Thái:</label>
                <select id="filterStatus" onchange="filterCars()">
                    <option value="">Tất Cả</option>
                    <option value="available">Sẵn Sàng</option>
                    <option value="rented">Đang Thuê</option>
                    <option value="maintenance">Bảo Dưỡng</option>
                </select>
            </div>
            <div class="search-box">
                <input type="text" id="searchCar" placeholder="🔍 Tìm kiếm theo biển số..." oninput="filterCars()">
            </div>
        </div>

        <!-- Stats row -->
        <div class="mini-stats">
            <span class="mini-stat">
                <span class="dot dot--green"></span>
                Sẵn Sàng: <strong>
                    <%= cars.filter(c=> c.status === 'available').length %>
                </strong>
            </span>
            <span class="mini-stat">
                <span class="dot dot--orange"></span>
                Đang Thuê: <strong>
                    <%= cars.filter(c=> c.status === 'rented').length %>
                </strong>
            </span>
            <span class="mini-stat">
                <span class="dot dot--red"></span>
                Bảo Dưỡng: <strong>
                    <%= cars.filter(c=> c.status === 'maintenance').length %>
                </strong>
            </span>
            <span class="mini-stat" style="margin-left: auto;">
                Tổng: <strong>
                    <%= cars.length %>
                </strong> xe
            </span>
        </div>

        <div class="card-container">
            <% if (cars.length===0) { %>
                <div class="empty-state">
                    <div class="empty-icon">🚗</div>
                    <h3>Chưa có xe nào</h3>
                    <p>Bắt đầu bằng cách thêm xe đầu tiên vào hệ thống.</p>
                    <button class="btn btn-action" onclick="openCarModal()">➕ Thêm Xe Ngay</button>
                </div>
            <% } else { %>
                <div class="card-list" id="carCards">
                    <% cars.forEach(function(car, index) { %>
                        <div class="car-card" data-status="<%= car.status %>" data-carnumber="<%= car.carNumber.toLowerCase() %>">
                            <div class="card-header">
                                <span class="card-index"><%= index+1 %></span>
                                <span class="status status-<%= car.status %>">
                                    <%= car.status==='available' ? 'Sẵn Sàng' : car.status==='rented' ? 'Đang Thuê' : 'Bảo Dưỡng' %>
                                </span>
                            </div>
                            <div class="card-body">
                                <p><strong>Biển số:</strong> <code class="car-code"><%= car.carNumber %></code></p>
                                <p><strong>Sức chứa:</strong> 🪑 <%= car.capacity %> chỗ</p>
                                <p><strong>Giá/ngày:</strong> <%= car.pricePerDay.toLocaleString('vi-VN') %> ₫</p>
                                <p><strong>Tính năng:</strong> <% if (car.features && car.features.length>0) { %>
                                    <%= car.features.join(', ') %>
                                    <% } else { %> <span class="text-muted">Không có</span><% } %></p>
                            </div>
                            <div class="card-footer">
                                <% if (car.status==='available') { %>
                                    <button class="btn btn-action btn-sm" onclick="openBookingModalWithCar('<%= car.carNumber %>')">📅 Đặt Xe</button>
                                <% } %>
                                <button class="btn btn-edit btn-sm" onclick='openEditCarModal(<%- JSON.stringify(car) %>)'>✏️ Sửa</button>
                                <button class="btn btn-danger btn-sm" onclick="deleteCar('<%= car._id %>', '<%= car.carNumber %>')">🗑️ Xóa</button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Add/Edit Car Modal -->
    <div id="carModal" class="modal-overlay" onclick="closeModal('carModal')">
        <div class="modal" onclick="event.stopPropagation()">
            <div class="modal-header">
                <h3 id="carModalTitle">➕ Thêm Xe Mới</h3>
                <button class="modal-close" onclick="closeModal('carModal')">✕</button>
            </div>
            <form id="carForm" onsubmit="submitCarForm(event)">
                <input type="hidden" id="carId" name="carId">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="carNumber">Biển Số Xe *</label>
                        <input type="text" id="carNumber" name="carNumber" placeholder="Ví dụ: 51A-12345" required>
                    </div>
                    <div class="form-group">
                        <label for="capacity">Sức Chứa (chỗ) *</label>
                        <input type="number" id="capacity" name="capacity" min="1" max="50" placeholder="Ví dụ: 5"
                            required>
                    </div>
                    <div class="form-group">
                        <label for="status">Trạng Thái *</label>
                        <select id="carStatus" name="status" required>
                            <option value="available">✅ Sẵn Sàng</option>
                            <option value="rented">🔑 Đang Thuê</option>
                            <option value="maintenance">🔧 Bảo Dưỡng</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="pricePerDay">Giá / Ngày (₫) *</label>
                        <input type="number" id="pricePerDay" name="pricePerDay" min="0" placeholder="Ví dụ: 500000"
                            required>
                    </div>
                    <div class="form-group form-group--full">
                        <label for="features">Tính Năng (phân cách bởi dấu phẩy)</label>
                        <input type="text" id="features" name="features" placeholder="Ví dụ: GPS, Điều hòa, Camera lùi">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" onclick="closeModal('carModal')">Hủy</button>
                    <button type="submit" class="btn btn-action">💾 Lưu</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Quick Booking Modal (from cars page) -->
    <div id="quickBookingModal" class="modal-overlay" onclick="closeModal('quickBookingModal')">
        <div class="modal" onclick="event.stopPropagation()">
            <div class="modal-header">
                <h3>📅 Đặt Xe Nhanh</h3>
                <button class="modal-close" onclick="closeModal('quickBookingModal')">✕</button>
            </div>
            <form id="quickBookingForm" onsubmit="submitQuickBooking(event)">
                <div class="form-grid">
                    <div class="form-group form-group--full">
                        <label for="qbCarNumber">Biển Số Xe</label>
                        <input type="text" id="qbCarNumber" name="carNumber" readonly class="input-readonly">
                    </div>
                    <div class="form-group form-group--full">
                        <label for="qbCustomerName">Tên Khách Hàng *</label>
                        <input type="text" id="qbCustomerName" name="customerName" placeholder="Nhập tên khách hàng"
                            required>
                    </div>
                    <div class="form-group">
                        <label for="qbStartDate">Ngày Bắt Đầu *</label>
                        <input type="datetime-local" id="qbStartDate" name="startDate" required>
                    </div>
                    <div class="form-group">
                        <label for="qbEndDate">Ngày Kết Thúc *</label>
                        <input type="datetime-local" id="qbEndDate" name="endDate" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" onclick="closeModal('quickBookingModal')">Hủy</button>
                    <button type="submit" class="btn btn-action">📅 Xác Nhận Đặt Xe</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Filter cars by status or search text (card mode)
        function filterCars() {
            const statusFilter = document.getElementById('filterStatus').value;
            const searchVal = document.getElementById('searchCar').value.toLowerCase();
            document.querySelectorAll('.car-card').forEach(card => {
                const matchStatus = !statusFilter || card.dataset.status === statusFilter;
                const matchSearch = !searchVal || card.dataset.carnumber.includes(searchVal);
                card.style.display = matchStatus && matchSearch ? '' : 'none';
            });
        }

        function openCarModal() {
            document.getElementById('carModalTitle').textContent = '➕ Thêm Xe Mới';
            document.getElementById('carForm').reset();
            document.getElementById('carId').value = '';
            document.getElementById('carModal').classList.add('active');
        }

        function openEditCarModal(car) {
            document.getElementById('carModalTitle').textContent = '✏️ Chỉnh Sửa Xe';
            document.getElementById('carId').value = car._id;
            document.getElementById('carNumber').value = car.carNumber;
            document.getElementById('capacity').value = car.capacity;
            document.getElementById('carStatus').value = car.status;
            document.getElementById('pricePerDay').value = car.pricePerDay;
            document.getElementById('features').value = (car.features || []).join(', ');
            document.getElementById('carModal').classList.add('active');
        }

        function openBookingModalWithCar(carNumber) {
            document.getElementById('qbCarNumber').value = carNumber;
            document.getElementById('quickBookingModal').classList.add('active');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        async function submitCarForm(event) {
            event.preventDefault();
            const carId = document.getElementById('carId').value;
            const isEdit = !!carId;
            const featuresRaw = document.getElementById('features').value;
            const features = featuresRaw ? featuresRaw.split(',').map(f => f.trim()).filter(Boolean) : [];

            const payload = {
                carNumber: document.getElementById('carNumber').value,
                capacity: parseInt(document.getElementById('capacity').value),
                status: document.getElementById('carStatus').value,
                pricePerDay: parseFloat(document.getElementById('pricePerDay').value),
                features
            };

            try {
                const url = isEdit ? `/api/cars/${carId}` : '/api/cars';
                const method = isEdit ? 'PUT' : 'POST';
                const res = await authFetch(url, {
                    method,
                    body: JSON.stringify(payload)
                });
                if (!res.ok) {
                    const err = await res.json();
                    showToast(err.message || 'Có lỗi xảy ra', 'error');
                    return;
                }
                showToast(isEdit ? '✅ Cập nhật xe thành công!' : '✅ Thêm xe mới thành công!', 'success');
                closeModal('carModal');
                setTimeout(() => location.reload(), 1000);
            } catch (e) {
                showToast('❌ Lỗi kết nối máy chủ', 'error');
            }
        }

        async function deleteCar(carId, carNumber) {
            if (!confirm(`Bạn có chắc muốn xóa xe ${carNumber}?`)) return;
            try {
                const res = await authFetch(`/api/cars/${carId}`, { method: 'DELETE' });
                if (!res.ok) {
                    const err = await res.json();
                    showToast(err.message || 'Không thể xóa xe', 'error');
                    return;
                }
                showToast(`✅ Đã xóa xe ${carNumber}`, 'success');
                setTimeout(() => location.reload(), 1000);
            } catch (e) {
                showToast('❌ Lỗi kết nối máy chủ', 'error');
            }
        }

        async function submitQuickBooking(event) {
            event.preventDefault();
            const payload = {
                carNumber: document.getElementById('qbCarNumber').value,
                customerName: document.getElementById('qbCustomerName').value,
                startDate: document.getElementById('qbStartDate').value,
                endDate: document.getElementById('qbEndDate').value
            };
            try {
                const res = await authFetch('/api/bookings', {
                    method: 'POST',
                    body: JSON.stringify(payload)
                });
                if (!res.ok) {
                    const err = await res.json();
                    showToast(err.message || 'Không thể tạo đặt xe', 'error');
                    return;
                }
                showToast('✅ Đặt xe thành công!', 'success');
                closeModal('quickBookingModal');
                setTimeout(() => location.reload(), 1000);
            } catch (e) {
                showToast('❌ Lỗi kết nối máy chủ', 'error');
            }
        }
    </script>

    <%- include('partials/footer') %>