<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách xe | Hệ thống Thuê xe Premium</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        :root {
            /* Premium Color Palette */
            --bg-color: #0f172a;
            --surface-color: rgba(30, 41, 59, 0.7);
            --surface-border: rgba(255, 255, 255, 0.1);
            --primary-gradient: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --badge-avail-bg: rgba(16, 185, 129, 0.15);
            --badge-avail-text: #34d399;
            --badge-rent-bg: rgba(59, 130, 246, 0.15);
            --badge-rent-text: #60a5fa;
            --badge-maint-bg: rgba(245, 158, 11, 0.15);
            --badge-maint-text: #fbbf24;

            /* Typography */
            --font-family: 'Outfit', sans-serif;
            --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--bg-color);
            background-image:
                radial-gradient(circle at 85% 15%, rgba(59, 130, 246, 0.12) 0%, transparent 40%),
                radial-gradient(circle at 15% 85%, rgba(139, 92, 246, 0.12) 0%, transparent 40%);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
            background-attachment: fixed;
        }

        /* Glassmorphism Header */
        .header {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--surface-border);
            padding: 1.2rem 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-logo {
            font-size: 1.5rem;
            font-weight: 800;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
            text-decoration: none;
        }

        .nav {
            display: flex;
            gap: 1.5rem;
        }

        .nav a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            font-size: 1rem;
            padding: 0.5rem 1.2rem;
            border-radius: 9999px;
            transition: var(--transition-smooth);
        }

        .nav a:hover {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.05);
        }

        .nav a.active {
            color: var(--text-main);
            background: var(--surface-border);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.05);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .user-info {
            font-size: 0.9rem;
            color: var(--text-muted);
            padding: 0.4rem 0.8rem;
            border-radius: 9999px;
            background: rgba(255,255,255,0.05);
        }
        .user-info span { color: #60a5fa; font-weight: 600; }
        .btn-logout {
            padding: 0.5rem 1rem;
            border-radius: 9999px;
            border: 1px solid rgba(239, 68, 68, 0.4);
            background: rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            font-family: inherit;
            transition: var(--transition-smooth);
        }
        .btn-logout:hover { background: rgba(239, 68, 68, 0.25); color: #fecaca; }

        /* Container */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 3rem 2rem;
            flex-grow: 1;
            width: 100%;
            animation: fadeIn 0.6s ease-out;
        }

        .page-header {
            margin-bottom: 3rem;
            text-align: center;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }

        .page-desc {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        /* Error/Loading state */
        .status-box {
            text-align: center;
            padding: 3rem;
            background: var(--surface-color);
            border-radius: 16px;
            border: 1px solid var(--surface-border);
            backdrop-filter: blur(10px);
            margin: 2rem auto;
            max-width: 600px;
        }

        .error {
            color: #fca5a5;
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.2);
        }

        /* Grid */
        .cars-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 2rem;
        }

        /* Card */
        .car-card {
            background: var(--surface-color);
            backdrop-filter: blur(10px);
            border: 1px solid var(--surface-border);
            border-radius: 20px;
            padding: 2rem;
            transition: var(--transition-smooth);
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            position: relative;
            overflow: hidden;
        }

        .car-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .car-card:hover {
            transform: translateY(-5px);
            background: rgba(30, 41, 59, 0.9);
            border-color: rgba(139, 92, 246, 0.3);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3), 0 0 15px rgba(139, 92, 246, 0.1);
        }

        .car-card:hover::before {
            opacity: 1;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .car-number {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--text-main);
            letter-spacing: 1px;
        }

        .badge {
            padding: 0.4rem 0.8rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .badge-available {
            background: var(--badge-avail-bg);
            color: var(--badge-avail-text);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .badge-rented {
            background: var(--badge-rent-bg);
            color: var(--badge-rent-text);
            border: 1px solid rgba(59, 130, 246, 0.3);
        }

        .badge-maintenance {
            background: var(--badge-maint-bg);
            color: var(--badge-maint-text);
            border: 1px solid rgba(245, 158, 11, 0.3);
        }

        .price-section {
            margin-top: 0.5rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--surface-border);
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .price-label {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 0.2rem;
        }

        .price-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: #a78bfa;
        }

        .price-unit {
            font-size: 0.9rem;
            font-weight: 400;
            color: var(--text-muted);
        }

        .details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .detail-item {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .detail-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detail-value {
            font-size: 1rem;
            font-weight: 500;
        }

        .features {
            margin-top: auto;
        }

        .feature-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        .tag {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--surface-border);
            padding: 0.2rem 0.6rem;
            border-radius: 6px;
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 768px) {
            .header {
                padding: 1rem 1.5rem;
                flex-direction: column;
                gap: 1rem;
            }

            .container {
                padding: 2rem 1.5rem;
            }

            .page-title {
                font-size: 2rem;
            }
        }
    </style>
</head>

<body>
    <header class="header">
        <a href="/" class="header-logo">CarRental</a>
        <nav class="nav">
            <a href="/">Trang chủ</a>
            <a href="/views/cars" class="active">Danh sách xe</a>
            <a href="/views/bookings">Đặt xe</a>
            <a href="/views/overdue">Quá hạn</a>
            <div class="nav-right">
                <div class="user-info" id="userInfo"></div>
                <button type="button" class="btn-logout" id="btnLogout">Đăng xuất</button>
            </div>
        </nav>
    </header>

    <main class="container">
        <div class="page-header">
            <h1 class="page-title">Garage Xe</h1>
            <p class="page-desc">Danh sách toàn bộ xe và trạng thái cập nhật theo thời gian thực</p>
        </div>

        <div class="status-box" style="max-width: 900px; margin: 0 auto 2rem;">
            <div style="font-weight: 700; font-size: 1.05rem; margin-bottom: 1rem;">Thêm xe mới</div>
            <form id="createCarForm" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; align-items:end;">
                <div>
                    <div style="font-size:.8rem; color: var(--text-muted); margin-bottom:.35rem; text-transform:uppercase; letter-spacing:.5px;">Biển số</div>
                    <input name="carNumber" required placeholder="51A-12345" style="width:100%; padding:.7rem .8rem; border-radius: 12px; border:1px solid var(--surface-border); background: rgba(15,23,42,.6); color: var(--text-main); outline:none;">
                </div>
                <div>
                    <div style="font-size:.8rem; color: var(--text-muted); margin-bottom:.35rem; text-transform:uppercase; letter-spacing:.5px;">Sức chứa</div>
                    <input name="capacity" type="number" min="1" placeholder="5" style="width:100%; padding:.7rem .8rem; border-radius: 12px; border:1px solid var(--surface-border); background: rgba(15,23,42,.6); color: var(--text-main); outline:none;">
                </div>
                <div>
                    <div style="font-size:.8rem; color: var(--text-muted); margin-bottom:.35rem; text-transform:uppercase; letter-spacing:.5px;">Giá/ngày (₫)</div>
                    <input name="pricePerDay" type="number" min="0" step="1000" placeholder="500000" style="width:100%; padding:.7rem .8rem; border-radius: 12px; border:1px solid var(--surface-border); background: rgba(15,23,42,.6); color: var(--text-main); outline:none;">
                </div>
                <div>
                    <div style="font-size:.8rem; color: var(--text-muted); margin-bottom:.35rem; text-transform:uppercase; letter-spacing:.5px;">Trạng thái</div>
                    <select name="status" style="width:100%; padding:.7rem .8rem; border-radius: 12px; border:1px solid var(--surface-border); background: rgba(15,23,42,.6); color: var(--text-main); outline:none;">
                        <option value="available">Sẵn sàng</option>
                        <option value="rented">Đang thuê</option>
                        <option value="maintenance">Bảo trì</option>
                    </select>
                </div>
                <div style="grid-column: 1 / -1;">
                    <div style="font-size:.8rem; color: var(--text-muted); margin-bottom:.35rem; text-transform:uppercase; letter-spacing:.5px;">Tiện nghi (ngăn cách bằng dấu phẩy)</div>
                    <input name="features" placeholder="Camera 360, Bluetooth, Điều hoà" style="width:100%; padding:.7rem .8rem; border-radius: 12px; border:1px solid var(--surface-border); background: rgba(15,23,42,.6); color: var(--text-main); outline:none;">
                </div>
                <div style="grid-column: 1 / -1; display:flex; gap:.75rem; align-items:center; justify-content:flex-end;">
                    <button type="submit" style="border:none; cursor:pointer; padding:.75rem 1rem; border-radius: 9999px; background: var(--primary-gradient); color: var(--text-main); font-weight: 700;">Tạo xe</button>
                    <div id="carFormMsg" style="color: var(--text-muted); font-size:.95rem;"></div>
                </div>
            </form>
        </div>

        <% if (!cars || cars.length===0) { %>
            <div id="statusBox" class="status-box">
                <div id="emptyText">📭 Chưa có thông tin xe trong hệ thống.</div>
            </div>
            <% } else { %>
                <div class="cars-grid">
                    <% cars.forEach(function(car, index) { let statusClass='' ; let statusText=car.status; if
                        (car.status==='available' ) { statusClass='badge-available' ; statusText='Sẵn sàng' ; } else if
                        (car.status==='rented' ) { statusClass='badge-rented' ; statusText='Đang thuê' ; } else if
                        (car.status==='maintenance' ) { statusClass='badge-maintenance' ; statusText='Bảo trì' ; } let
                        tagsHtml='—' ; if (Array.isArray(car.features) && car.features.length> 0) {
                        tagsHtml = car.features.map(f => `<span class="tag">${f}</span>`).join('');
                        } else if (typeof car.features === 'string') {
                        tagsHtml = car.features.split(',').map(f => `<span class="tag">${f.trim()}</span>`).join('');
                        }

                        function formatPrice(n) {
                        if (n == null || n === '') return '—';
                        return new Intl.NumberFormat('vi-VN').format(n);
                        }
                        %>
                        <div class="car-card" style="animation: fadeIn 0.5s ease-out <%= index * 0.1 %>s both">
                            <div class="card-header">
                                <div class="car-number">
                                    <%= car.carNumber || '—' %>
                                </div>
                                <div class="badge <%= statusClass %>">
                                    <%= statusText %>
                                </div>
                            </div>

                            <div class="details">
                                <div class="detail-item">
                                    <span class="detail-label">Sức chứa</span>
                                    <span class="detail-value">👥 <%= car.capacity ?? '—' %> chỗ</span>
                                </div>
                            </div>

                            <div class="features">
                                <div class="detail-label" style="margin-bottom: 0.5rem">Tiện nghi</div>
                                <div class="feature-tags">
                                    <%- tagsHtml %>
                                </div>
                            </div>

                            <div class="price-section">
                                <div>
                                    <div class="price-label">Giá thuê / ngày</div>
                                    <div class="price-value">
                                        <%= formatPrice(car.pricePerDay) %><span class="price-unit">₫</span>
                                    </div>
                                </div>
                                <button class="delete-btn" data-id="<%= car._id %>" style="border:1px solid rgba(239,68,68,.35); background: rgba(239,68,68,.12); color:#fecaca; padding:.55rem .85rem; border-radius: 9999px; cursor:pointer; font-weight:700;">
                                    Xoá
                                </button>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } %>
    </main>

    <script>
        (function () {
            var token = localStorage.getItem('token');
            if (!token) {
                window.location.href = '/views/login';
                return;
            }
            var userStr = localStorage.getItem('user');
            if (userStr) {
                try {
                    var user = JSON.parse(userStr);
                    var el = document.getElementById('userInfo');
                    if (el) el.innerHTML = '<span>' + (user.email || user.fullName || 'User') + '</span>';
                } catch (e) {}
            }
        })();
        document.getElementById('btnLogout').addEventListener('click', function () {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            window.location.href = '/views/login';
        });
        function getAuthHeaders() {
            var t = localStorage.getItem('token');
            return t ? { 'Authorization': 'Bearer ' + t } : {};
        }
        function showMsg(el, text, ok) {
            el.textContent = text;
            el.style.color = ok ? '#34d399' : '#fca5a5';
        }

        document.getElementById('createCarForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const msg = document.getElementById('carFormMsg');
            showMsg(msg, 'Đang tạo...', true);

            const fd = new FormData(this);
            const featuresRaw = (fd.get('features') || '').toString().trim();
            const payload = {
                carNumber: (fd.get('carNumber') || '').toString().trim(),
                capacity: fd.get('capacity') ? Number(fd.get('capacity')) : undefined,
                pricePerDay: fd.get('pricePerDay') ? Number(fd.get('pricePerDay')) : undefined,
                status: (fd.get('status') || 'available').toString(),
                features: featuresRaw ? featuresRaw.split(',').map(s => s.trim()).filter(Boolean) : []
            };

            try {
                const res = await fetch('/cars', {
                    method: 'POST',
                    headers: Object.assign({ 'Content-Type': 'application/json' }, getAuthHeaders()),
                    body: JSON.stringify(payload)
                });
                const data = await res.json().catch(() => ({}));
                if (res.ok) {
                    showMsg(msg, 'Tạo xe thành công. Đang tải lại...', true);
                    setTimeout(() => window.location.reload(), 800);
                } else {
                    if (res.status === 401) { window.location.href = '/views/login'; return; }
                    showMsg(msg, 'Lỗi: ' + (data.message || data.error || res.status), false);
                }
            } catch (err) {
                showMsg(msg, 'Gửi yêu cầu thất bại: ' + err.message, false);
            }
        });

        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', async function () {
                const id = this.getAttribute('data-id');
                if (!id) return;
                if (!confirm('Xoá xe này?')) return;
                this.disabled = true;
                this.style.opacity = 0.6;
                try {
                    const res = await fetch('/cars/' + encodeURIComponent(id), {
                        method: 'DELETE',
                        headers: getAuthHeaders()
                    });
                    const data = await res.json().catch(() => ({}));
                    if (res.ok) {
                        window.location.reload();
                    } else {
                        if (res.status === 401) { window.location.href = '/views/login'; return; }
                        alert('Lỗi: ' + (data.message || data.error || res.status));
                        this.disabled = false;
                        this.style.opacity = 1;
                    }
                } catch (err) {
                    alert('Gửi yêu cầu thất bại: ' + err.message);
                    this.disabled = false;
                    this.style.opacity = 1;
                }
            });
        });
    </script>
</body>

</html>