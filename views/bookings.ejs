<%- include('partials/header', { title: 'Quản Lý Đặt Xe' , activePage: 'bookings' }) %>

    <div class="container">
        <div class="page-header">
            <div class="section-title">
                <h2>📅 Quản Lý Đặt Xe</h2>
                <p>Xem và quản lý toàn bộ lịch sử đặt thuê xe.</p>
            </div>
            <button class="btn btn-action" onclick="openBookingModal()">
                ➕ Tạo Đặt Xe
            </button>
        </div>

        <!-- Filter Bar -->
        <div class="filter-bar">
            <div class="filter-group">
                <label for="filterBookingStatus">Trạng Thái:</label>
                <select id="filterBookingStatus" onchange="filterBookings()">
                    <option value="">Tất Cả</option>
                    <option value="active">Đang Hoạt Động</option>
                    <option value="upcoming">Sắp Tới</option>
                    <option value="completed">Hoàn Thành</option>
                </select>
            </div>
            <div class="search-box">
                <input type="text" id="searchBooking" placeholder="🔍 Tìm theo tên KH hoặc xe..."
                    oninput="filterBookings()">
            </div>
        </div>

        <!-- Stats Row -->
        <div class="mini-stats">
            <% const now=new Date(); let activeCount=0, upcomingCount=0, completedCount=0; bookings.forEach(b=> {
                const start = new Date(b.startDate);
                const end = b.endDate ? new Date(b.endDate) : null;
                if (!end || end < now) completedCount++; else if (start> now) upcomingCount++;
                    else activeCount++;
                    });
                    const totalRevenue = bookings.reduce((sum, b) => sum + (b.totalAmount || 0), 0);
                    %>
                    <span class="mini-stat">
                        <span class="dot dot--green"></span>
                        Đang Thuê: <strong>
                            <%= activeCount %>
                        </strong>
                    </span>
                    <span class="mini-stat">
                        <span class="dot dot--orange"></span>
                        Sắp Tới: <strong>
                            <%= upcomingCount %>
                        </strong>
                    </span>
                    <span class="mini-stat">
                        <span class="dot dot--gray"></span>
                        Hoàn Thành: <strong>
                            <%= completedCount %>
                        </strong>
                    </span>
                    <span class="mini-stat" style="margin-left: auto;">
                        Doanh Thu: <strong class="text-green">
                            <%= totalRevenue.toLocaleString('vi-VN') %> ₫
                        </strong>
                    </span>
        </div>

        <div class="card-container">
            <% if (bookings.length===0) { %>
                <div class="empty-state">
                    <div class="empty-icon">📅</div>
                    <h3>Chưa có đặt xe nào</h3>
                    <p>Bắt đầu bằng cách tạo đặt xe đầu tiên.</p>
                    <button class="btn btn-action" onclick="openBookingModal()">➕ Tạo Ngay</button>
                </div>
            <% } else { %>
                <div class="card-list" id="bookingCards">
                    <% bookings.forEach(function(booking, index) { %>
                        <% const bStart=new Date(booking.startDate);
                           const bEnd=booking.endDate ? new Date(booking.endDate) : null;
                           let bStatusClass='status-available';
                           let bStatusText='Đang Thuê';
                           let bStatusKey='active';
                           if (!bEnd || bEnd < now) { bStatusClass='status-completed'; bStatusText='Hoàn Thành'; bStatusKey='completed'; }
                           else if (bStart> now) { bStatusClass = 'status-rented'; bStatusText = 'Sắp Tới'; bStatusKey = 'upcoming'; }
                        %>
                        <div class="booking-card" data-status="<%= bStatusKey %>" data-search="<%= (booking.customerName + ' ' + booking.carNumber).toLowerCase() %>">
                            <div class="card-header">
                                <span class="card-index"><%= index+1 %></span>
                                <span class="status <%= bStatusClass %>"><%= bStatusText %></span>
                            </div>
                            <div class="card-body">
                                <p><strong>KH:</strong> <%= booking.customerName %></p>
                                <p><strong>Xe:</strong> <code class="car-code"><%= booking.carNumber %></code></p>
                                <p><strong>Bắt đầu:</strong> <%= new Date(booking.startDate).toLocaleString('vi-VN', {dateStyle:'short', timeStyle:'short'}) %></p>
                                <p><strong>Kết thúc:</strong> <% if (booking.endDate) { %><%= new Date(booking.endDate).toLocaleString('vi-VN', {dateStyle:'short', timeStyle:'short'}) %><% } else { %><span class="text-muted">Chưa xác định</span><% } %></p>
                                <p class="amount"><strong>Thành tiền:</strong> <%= booking.totalAmount.toLocaleString('vi-VN') %> ₫</p>
                            </div>
                            <div class="card-footer">
                                <button class="btn btn-edit btn-sm" onclick='openEditBookingModal(<%- JSON.stringify(booking) %>)'>✏️ Sửa</button>
                                <button class="btn btn-danger btn-sm" onclick="deleteBooking('<%= booking._id %>', '<%= booking.customerName %>')">🗑️ Xóa</button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Add/Edit Booking Modal -->
    <div id="bookingModal" class="modal-overlay" onclick="closeModal('bookingModal')">
        <div class="modal" onclick="event.stopPropagation()">
            <div class="modal-header">
                <h3 id="bookingModalTitle">📅 Tạo Đặt Xe Mới</h3>
                <button class="modal-close" onclick="closeModal('bookingModal')">✕</button>
            </div>
            <form id="bookingForm" onsubmit="submitBookingForm(event)">
                <input type="hidden" id="bookingId" name="bookingId">
                <div class="form-grid">
                    <div class="form-group form-group--full">
                        <label for="bCustomerName">Tên Khách Hàng *</label>
                        <input type="text" id="bCustomerName" name="customerName" placeholder="Nhập tên khách hàng"
                            required>
                    </div>
                    <div class="form-group form-group--full">
                        <label for="bCarNumber">Biển Số Xe *</label>
                        <input type="text" id="bCarNumber" name="carNumber" placeholder="Ví dụ: 51A-12345" required>
                    </div>
                    <div class="form-group">
                        <label for="bStartDate">Ngày Bắt Đầu *</label>
                        <input type="datetime-local" id="bStartDate" name="startDate" required>
                    </div>
                    <div class="form-group">
                        <label for="bEndDate">Ngày Kết Thúc *</label>
                        <input type="datetime-local" id="bEndDate" name="endDate" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" onclick="closeModal('bookingModal')">Hủy</button>
                    <button type="submit" class="btn btn-action">💾 Lưu Đặt Xe</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function filterBookings() {
            const statusFilter = document.getElementById('filterBookingStatus').value;
            const searchVal = document.getElementById('searchBooking').value.toLowerCase();
            document.querySelectorAll('.booking-card').forEach(card => {
                const matchStatus = !statusFilter || card.dataset.status === statusFilter;
                const matchSearch = !searchVal || card.dataset.search.includes(searchVal);
                card.style.display = matchStatus && matchSearch ? '' : 'none';
            });
        }

        function openBookingModal() {
            document.getElementById('bookingModalTitle').textContent = '📅 Tạo Đặt Xe Mới';
            document.getElementById('bookingForm').reset();
            document.getElementById('bookingId').value = '';
            document.getElementById('bookingModal').classList.add('active');
        }

        function openEditBookingModal(booking) {
            document.getElementById('bookingModalTitle').textContent = '✏️ Chỉnh Sửa Đặt Xe';
            document.getElementById('bookingId').value = booking._id;
            document.getElementById('bCustomerName').value = booking.customerName;
            document.getElementById('bCarNumber').value = booking.carNumber;

            // Format dates for datetime-local input
            const toLocal = (dateStr) => {
                const d = new Date(dateStr);
                const offset = d.getTimezoneOffset();
                const local = new Date(d.getTime() - offset * 60000);
                return local.toISOString().slice(0, 16);
            };
            document.getElementById('bStartDate').value = toLocal(booking.startDate);
            if (booking.endDate) {
                document.getElementById('bEndDate').value = toLocal(booking.endDate);
            }
            document.getElementById('bookingModal').classList.add('active');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        async function submitBookingForm(event) {
            event.preventDefault();
            const bookingId = document.getElementById('bookingId').value;
            const isEdit = !!bookingId;

            const payload = {
                customerName: document.getElementById('bCustomerName').value,
                carNumber: document.getElementById('bCarNumber').value,
                startDate: document.getElementById('bStartDate').value,
                endDate: document.getElementById('bEndDate').value
            };

            try {
                const url = isEdit ? `/api/bookings/${bookingId}` : '/api/bookings';
                const method = isEdit ? 'PUT' : 'POST';
                const res = await authFetch(url, {
                    method,
                    body: JSON.stringify(payload)
                });
                if (!res.ok) {
                    const err = await res.json();
                    showToast(err.message || 'Có lỗi xảy ra', 'error');
                    return;
                }
                showToast(isEdit ? '✅ Cập nhật đặt xe thành công!' : '✅ Tạo đặt xe thành công!', 'success');
                closeModal('bookingModal');
                setTimeout(() => location.reload(), 1000);
            } catch (e) {
                showToast('❌ Lỗi kết nối máy chủ', 'error');
            }
        }

        async function deleteBooking(bookingId, customerName) {
            if (!confirm(`Bạn có chắc muốn xóa đặt xe của ${customerName}?`)) return;
            try {
                const res = await authFetch(`/api/bookings/${bookingId}`, { method: 'DELETE' });
                if (!res.ok) {
                    const err = await res.json();
                    showToast(err.message || 'Không thể xóa đặt xe', 'error');
                    return;
                }
                showToast(`✅ Đã xóa đặt xe của ${customerName}`, 'success');
                setTimeout(() => location.reload(), 1000);
            } catch (e) {
                showToast('❌ Lỗi kết nối máy chủ', 'error');
            }
        }
    </script>

    <%- include('partials/footer') %>